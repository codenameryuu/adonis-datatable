{
  "name": "@codenameryuu/adonis-datatable",
  "description": "Server side datatables package for Adonis JS",
  "version": "1.9.1",
  "author": "codenameryuu",
  "license": "MIT",
  "homepage": "https://github.com/codenameryuu/adonis-datatable#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenameryuu/adonis-datatable.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "files": [
    "build/src",
    "build/services",
    "build/providers",
    "build/stubs",
    "build/index.d.ts",
    "build/index.js",
    "build/configure.d.ts",
    "build/configure.js"
  ],
  "exports": {
    ".": "./build/index.js",
    "./datatables_provider": "./build/providers/datatables_provider.js",
    "./services/main": "./build/services/main.js",
    "./engines/lucid_datatable": "./build/src/engines/lucid_datatable.js",
    "./engines/database_datatable": "./build/src/engines/database_datatable.js",
    "./engines/object_datatable": "./build/src/engines/object_datatable.js",
    "./types": "./build/src/types/index.js"
  },
  "scripts": {
    "clean": "del-cli build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "copy:templates": "copyfiles -u 1 \"stubs/**/*.stub\" build/stubs",
    "build": "npm run clean && tsc && npm run copy:templates",
    "release": "release-it",
    "version": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.7.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@japa/snapshot": "^2.0.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "@swc/core": "^1.6.3",
    "@types/lodash": "^4.17.7",
    "@types/node": "^25.5.0",
    "@types/sprintf-js": "^1.1.4",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "del-cli": "^7.0.0",
    "luxon": "^3.4.4",
    "openapi-types": "^12.1.3",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "collect.js": "^4.36.1",
    "edge.js": "^6.2.1",
    "lodash": "^4.17.21",
    "sprintf-js": "^1.1.3"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0"
  },
  "keywords": [
    "datatables",
    "adonis",
    "adonisjs"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "prettier": "@adonisjs/prettier-config",
  "np": {
    "message": "chore(release): %s",
    "tag": "latest",
    "branch": "main",
    "anyBranch": false
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "v${version}",
      "push": true,
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  }
}
